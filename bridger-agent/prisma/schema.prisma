generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Session {
  id Int @id @default(autoincrement())
  transactions Transaction[]
}

model Transaction {
  id Int @id @default(autoincrement())
  sessionId Int
  session Session @relation(fields: [sessionId], references: [id])
  // Model predictions
  vendor String?
  account String?
  unsure Boolean
  // Transaction info
  date DateTime
  // Positive for money in, negative for money out
  amountCents Int
  bankDetail String
  // User set fields
  correctedVendor String?
  correctedAccount String?
  needsInfo Boolean @default(false)
  validated Boolean @default(false)
}